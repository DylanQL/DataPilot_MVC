<%- include('partials/head', { title: 'Login | DataPilot MVC' }) %>

<main class="auth-shell">
  <section class="auth-card glass">
    <div class="auth-brand">
      <i class="bi bi-database-check"></i>
      <h1>DataPilot MVC</h1>
      <p>Gestiona tus tablas MySQL con WebSocket en tiempo real</p>
    </div>

    <% if (error) { %>
      <div class="alert error"><i class="bi bi-exclamation-octagon"></i> <%= error %></div>
    <% } %>

    <form method="POST" action="/login" class="auth-form">
      <label>
        Usuario
        <input type="text" name="username" placeholder="tu_usuario" required />
      </label>
      <label>
        Contrasena
        <input type="password" name="password" placeholder="********" required />
      </label>
      <button type="submit" class="btn btn-primary">
        <i class="bi bi-box-arrow-in-right"></i>
        Ingresar
      </button>
    </form>
  </section>
</main>

<%- include('partials/footer') %>
