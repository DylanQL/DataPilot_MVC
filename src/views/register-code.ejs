<%- include('partials/head', { title: 'Registro | Verificacion' }) %>

<main class="auth-shell">
  <section class="auth-card glass register-card verify-card">
    <div class="auth-brand verify-brand">
      <i class="bi bi-shield-check"></i>
      <h1>Verifica tu correo</h1>
      <p>Te enviamos un codigo de 6 digitos a</p>
      <p class="verify-email"><strong><%= email %></strong></p>
    </div>

    <% if (error) { %>
      <div class="alert error"><i class="bi bi-exclamation-octagon"></i> <%= error %></div>
    <% } %>

    <form id="verifyCodeForm" class="auth-form verify-form">
      <div class="otp-grid" id="otpGrid">
        <input class="otp-input" type="text" inputmode="numeric" maxlength="1" data-index="0" />
        <input class="otp-input" type="text" inputmode="numeric" maxlength="1" data-index="1" />
        <input class="otp-input" type="text" inputmode="numeric" maxlength="1" data-index="2" />
        <input class="otp-input" type="text" inputmode="numeric" maxlength="1" data-index="3" />
        <input class="otp-input" type="text" inputmode="numeric" maxlength="1" data-index="4" />
        <input class="otp-input" type="text" inputmode="numeric" maxlength="1" data-index="5" />
      </div>
      <input type="hidden" id="verificationCode" />

      <p class="tiny muted verify-help">Ingresa el codigo de 6 digitos que enviamos a tu correo.</p>

      <button type="submit" class="btn btn-primary verify-submit">
        <i class="bi bi-check2-circle"></i>
        Verificar codigo
      </button>

      <p id="registerStatus" class="verify-status muted"></p>

      <p class="verify-resend muted">
        No recibiste el codigo?
        <button id="sendCodeBtn" type="button" class="link-btn">Reenviar</button>
      </p>
    </form>

    <div id="registerMessage" class="verify-message"></div>

    <div class="verify-divider"></div>
    <a href="/register" class="verify-back-link"><i class="bi bi-arrow-left"></i> Cambiar correo</a>
  </section>
</main>

<script>
  window.__REGISTER_CODE_DATA__ = {
    email: <%- JSON.stringify(email) %>,
    allowedDomain: <%- JSON.stringify(allowedDomain) %>
  };
</script>
<script src="/js/register-code.js"></script>

<%- include('partials/footer') %>
